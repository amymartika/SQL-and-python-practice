# Challenge: Write a function
# Given a year, determine whether it is a leap year. 
# If it is a leap year, return the Boolena True. 
# Otherwise, return False. 

def is_leap(year):
    leap = ()
    
    if (year % 4 == 0 and year % 100 != 0) or (year % 400 == 0):
        leap = True
    else: 
        leap = False
    return leap

year = int(input())
print(is_leap(year))

# Challenge: Triangle Quest
# You are given a positive integer N. 
# Print a numerical triangle height of N-1. 
# Can you do it using only arithmetic operations, a single for loop, 
# and print statement in only 2 lines of code?
# Do not use anything related to strings.

for i in range(1, int(input())): 
    print((i) * (pow(10, i) - 1) // 9)
